import tkinter as tk 
import random

last_password = ""

root = tk.Tk()
root.title("Generate Password")
root.geometry("750x750")

label = tk.Label(root,text="Enter password length: ")
label.pack(expand=True)


entry = tk.Entry(root,width=25)
entry.pack()

def generate_password():
    global last_password

    try:
        length = int(entry.get())
    except ValueError:
        label_result.config(text="Enter a number!")
        return
    if length < 1:
       length = 1
    if length > 30:
       length = 30
    chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    password = ""

    for i in range(length):
      password += random.choice(chars)

    last_password = password
    label_result.config(text=password)

label_result = tk.Label(root,text="")
label_result.pack()

def copy_password():
    if last_password == "":
        label_result.config(text="Generate password first!")
        return
    root.clipboard_clear()
    root.clipboard_append(last_password)

copy_button = tk.Button(root, text="Copy", command=copy_password)
copy_button.pack()

button = tk.Button(root, text="Generate" ,command=generate_password)
button.pack(expand=True)

root.mainloop()
